{
  // Port for the proxy server (default: 8766)
  "port": 8766,

  // Per-request aiohttp.access log lines (default: true). They double
  // as the proxy's audit trail; set false for quieter logs.
  // "access_log": false,

  // Timeout settings (seconds)
  "timeouts": {
    "cli": 60,   // CLI subprocess timeout
    "http": 30   // Outbound HTTP request timeout
  },

  "plugins": {
    // GitHub: gh CLI + git smart HTTP proxy
    "github": {
      // Credentials are evaluated top-to-bottom, first match wins.
      //
      // Recommended strategy:
      //   1. Fine-grained PATs scoped to specific orgs/users (least privilege)
      //   2. Classic PAT for repos that don't support fine-grained PATs
      //   3. Broad fine-grained PAT as fallback for public repos
      "credentials": [
        // Fine-grained PAT scoped to your org
        {
          "token": "github_pat_YOUR_ORG_PAT",
          "resources": ["your-org/*"]
        },

        // Fine-grained PAT scoped to your personal repos
        {
          "token": "github_pat_YOUR_PERSONAL_PAT",
          "resources": ["your-username/*"]
        },

        // GitHub App: installation tokens minted automatically from the
        // App's private key (short-lived, cached, auto-refreshed).
        // Works where fine-grained PATs fall short — e.g. GitHub's Git LFS
        // batch API rejects fine-grained PATs but accepts these.
        {
          "app_id": 123456,
          // number at the end of the installation URL:
          // github.com/organizations/YOUR_ORG/settings/installations/<id>
          "installation_id": 12345678,
          "private_key_path": "/path/to/github-app.private-key.pem",
          // optional: narrow each minted token to the matched repository
          // ("matched"), or to a fixed list; omit to cover the whole
          // installation
          "repositories": "matched",
          // optional: cap permissions per token; omit for the App's defaults
          "permissions": { "contents": "write" },
          "resources": ["your-org/*"]
        },

        // Classic PAT for external repos that need write access
        // (some orgs/repos don't accept fine-grained PATs from outside collaborators)
        {
          "token": "ghp_YOUR_CLASSIC_PAT",
          "resources": [
            "some-org/specific-repo",
            "another-org/another-repo"
          ]
        },

        // Broad fine-grained PAT as fallback (e.g. for reading public repos)
        {
          "token": "github_pat_YOUR_FALLBACK_PAT",
          "resources": ["*"]
        }
      ]
    },

    // Langfuse: langfuse CLI (LLM tracing/prompts)
    //
    // Langfuse API keys are per-project, so configure one entry per
    // project. The client selects an entry with --project <name> /
    // FGAP_LANGFUSE_PROJECT (matched against "resources", first match
    // wins). Prefer explicit project names over "*" so a typo fails
    // instead of silently falling through to another project.
    //
    // "permissions" is required: "read" allows list/get (and
    // "api __schema"), "write" allows create/update/delete. Unrecognized
    // verbs are always denied.
    "langfuse": {
      "credentials": [
        {
          "public_key": "pk-lf-YOUR_PROD_PUBLIC_KEY",
          "secret_key": "sk-lf-YOUR_PROD_SECRET_KEY",
          // Optional: override for self-hosted or US region
          // "host": "https://us.cloud.langfuse.com",
          "resources": ["my-project-prod"],
          "permissions": ["read"]
        },
        {
          "public_key": "pk-lf-YOUR_STAGING_PUBLIC_KEY",
          "secret_key": "sk-lf-YOUR_STAGING_SECRET_KEY",
          "resources": ["my-project-staging"],
          "permissions": ["read"]
        }
      ]
    },

    // AWS: read-only aws CLI (observability: logs / ecs / cloudwatch / ecr)
    //
    // The plugin enforces a curated read-only allowlist per service:
    // write operations, secret-returning reads (ssm, secretsmanager),
    // credential minting (ecr get-login-password) and long-running
    // streams (--follow) are denied at the proxy. Pair the credential
    // with a read-only IAM principal (aws-readonly-policy.example.json)
    // so the guarantee holds in two independent layers.
    //
    // The grant is account-wide per service, not per workload: if
    // multiple workloads share the account, reads span all of them.
    "aws": {
      "credentials": [
        {
          // Proxy-host AWS profile (resolved by the host's ~/.aws,
          // SSO works). Alternative: "access_key_id" + "secret_access_key".
          "profile": "my-readonly-profile",
          "region": "us-east-1",
          // Account alias the client selects with --account /
          // FGAP_AWS_ACCOUNT (no default).
          "resources": ["my-account"],
          // Services opted in for this entry (subset of the supported
          // read-only set: cloudwatch, ecr, ecs, logs).
          "services": ["logs", "ecs", "cloudwatch", "ecr"]
        }
      ]
    },

    // Generic HTTP forward proxy (no CLI wrapper — sandbox uses curl):
    //     curl $FGAP_PROXY_URL/proxy/<service>/<path>
    //
    // Auth modes: "bearer" / "basic" / "header" (arbitrary header name,
    // e.g. for x-api-key-style APIs including MCP servers) / "oauth2".
    //
    // MCP support: passes MCP Streamable HTTP traffic, including
    // text/event-stream responses (relayed chunk by chunk, not buffered).
    //
    // Streaming upstreams (SSE MCP servers, LLM APIs): set
    // "streaming": true on the service. Those requests go through an
    // HTTP/2-capable client (some edges only pass SSE through
    // unbuffered on h2) and are not capped by a total timeout —
    // only connect (30s) and an idle-read guard
    // ("stream_idle_timeout" seconds, default 300).
    "http_proxy": {
      // Where oauth2 token state (access/refresh token, expiry) is
      // persisted. Default: /var/lib/fgap/tokens
      // "state_dir": "/var/lib/fgap/tokens",
      "services": {
        "some_mcp": {
          "upstream": "https://mcp.example.com",
          "auth": "header",
          "header_name": "x-api-key",  // required when auth = "header"
          "credentials": [
            { "token": "sk_YOUR_KEY", "resources": ["*"] }
          ]
        }
        // Static bearer token, inline:
        // "myapi": {
        //   "upstream": "https://api.example.com",
        //   "auth": "bearer",
        //   "credentials": [
        //     { "token": "YOUR_ACCESS_TOKEN", "resources": ["*"] }
        //   ]
        // },

        // Streaming LLM API with a static bearer token read from a file
        // — e.g. the Anthropic API in front of a Claude Code container:
        // the container runs with ANTHROPIC_BASE_URL={proxy}/proxy/anthropic
        // and ANTHROPIC_AUTH_TOKEN=dummy, so the real credential never
        // enters the sandbox. A Claude subscription mints the long-lived
        // token with `claude setup-token`; save it (single line, chmod 600)
        // to the token_file below. The file is re-read on every request,
        // so replacing its contents rotates the credential without a
        // restart.
        // "anthropic": {
        //   "upstream": "https://api.anthropic.com",
        //   "auth": "bearer",
        //   "streaming": true,
        //   // forward the client's own protocol headers…
        //   "forward_request_headers": ["anthropic-version", "anthropic-beta"],
        //   // …and pin required flags without clobbering them
        //   // (comma-merged into the client's value):
        //   "append_headers": { "anthropic-beta": "oauth-2025-04-20" },
        //   "credentials": [
        //     { "token_file": "~/.config/fgap/tokens/anthropic-bearer.txt",
        //       "resources": ["*"] }
        //   ]
        // },

        // OAuth2 with automatic token refresh — seed interactively on the
        // proxy host:  fgap-oauth-login --config <this file> --service <name>
        // (see README for the field-verified Anthropic oauth2 config, the
        // alternative when `claude setup-token` is not an option):
        // "freee": {
        //   "upstream": "https://api.freee.co.jp",
        //   "auth": "oauth2",
        //   "oauth2": {
        //     "token_url": "https://accounts.secure.freee.co.jp/public_api/token",
        //     "client_id": "YOUR_CLIENT_ID",
        //     "client_secret": "YOUR_CLIENT_SECRET",
        //     "refresh_token": "YOUR_REFRESH_TOKEN"
        //   }
        // }
        // See plugin.py docstring for all auth modes (bearer / basic / header / oauth2)
      }
    },

    // Fly.io: flyctl with per-app token injection. The resource is the
    // Fly app name, so tokens can be scoped per app or app family.
    // Commands needing the caller's working directory (deploy etc.)
    // receive the app's token as a logged handout — Fly's API refuses
    // to let tokens mint ephemeral sub-tokens (see fgap-fly --help).
    // Requires flyctl on the proxy host.
    "fly": {
      "credentials": [
        // Recommended: one deploy token per app. The `credential`
        // handout gives the client exactly the token configured here,
        // so per-app tokens keep every handout app-scoped.
        {
          // fly tokens create deploy -a my-app
          "token": "FlyV1 fm2_YOUR_APP_TOKEN",
          "resources": ["my-app"]
        },
        {
          "token": "FlyV1 fm2_YOUR_OTHER_APP_TOKEN",
          "resources": ["my-other-app"]
        }
        // A single org-wide token also works for proxy-side commands
        // (fly tokens create org -o your-org, resources: ["*"]), but
        // beware: local-context commands (deploy etc.) would then hand
        // the org-wide token out to the client.
      ]
    },

    // Notion: notion CLI (4ier/notion-cli)
    "notion": {
      "credentials": [
        {
          // Internal Integration Token from https://www.notion.so/profile/integrations
          "token": "ntn_YOUR_INTEGRATION_TOKEN",
          "resources": ["*"]
        }
      ]
    },

    // S3: proxy to S3-compatible storage (AWS S3, Cloudflare R2, MinIO)
    // with SigV4 re-signing. The sandbox uses a stock S3 client (aws cli,
    // rclone, boto3) with dummy credentials, pointed at
    // $FGAP_PROXY_URL/s3/{service} (path-style addressing required).
    "s3": {
      "services": {
        // "media": {
        //   // S3 API endpoint (for R2: https://ACCOUNT_ID.r2.cloudflarestorage.com)
        //   "endpoint": "https://ACCOUNT_ID.r2.cloudflarestorage.com",
        //   "region": "auto",
        //   "access_key_id": "YOUR_ACCESS_KEY_ID",
        //   "secret_access_key": "YOUR_SECRET_ACCESS_KEY",
        //   // Optional: allow-list of buckets (omit to allow all)
        //   "buckets": ["my-bucket"],
        //   // Optional: deny destructive operations.
        //   // "delete" rejects DeleteObject/DeleteObjects/DeleteBucket
        //   // (AbortMultipartUpload stays allowed).
        //   "deny": ["delete"],
        //   // Optional: inject If-None-Match: * into object-creating
        //   // requests so existing keys can never be overwritten
        //   // (requires conditional-write support upstream, e.g. R2/S3).
        //   "immutable_puts": true,
        //   // Optional: per-transfer timeout in seconds (default 600)
        //   "timeout": 600
        // }
      }
    },

    // Google: gog CLI (Google Workspace)
    "google": {
      "credentials": [
        // Option 1: OAuth (keyring-based)
        {
          // Password for gog's keyring (~/.config/gogcli/)
          "keyring_password": "your-keyring-password",

          // Optional: restrict to a specific Google account
          // "account": "user@gmail.com",

          "resources": ["*"]
        },

        // Option 2: Service account (no OAuth needed, no token expiry)
        // The SA can only access resources explicitly shared with its email.
        // {
        //   "sa_key_file": "/path/to/service-account-key.json",
        //   "account": "my-sa@my-project.iam.gserviceaccount.com",
        //   "resources": ["*"]
        // }
      ]
    }
  }

  // Managed local processes: helpers the proxy spawns on startup,
  // restarts on crash (exponential backoff), and terminates on
  // shutdown — typically stdio MCP servers wrapped by a stdio-to-HTTP
  // bridge, with their API keys in env on the proxy host. Pair each
  // with an http_proxy service whose upstream is the local port, so
  // the sandbox reaches the helper through the proxy and never sees
  // the credential. Status: GET /processes.
  //
  // "managed_processes": {
  //   "some-mcp": {
  //     "command": ["npx", "-y", "supergateway",
  //                 "--stdio", "npx -y some-mcp-server",
  //                 "--outputTransport", "streamableHttp",
  //                 "--port", "9101"],
  //     "env": { "SOME_API_KEY": "sk_YOUR_KEY" },
  //     "restart": true
  //   }
  // }
}
