{
  // Port for the proxy server (default: 8766)
  "port": 8766,

  // Timeout settings (seconds)
  "timeouts": {
    "cli": 60,   // CLI subprocess timeout
    "http": 30   // Outbound HTTP request timeout
  },

  "plugins": {
    // GitHub: gh CLI + git smart HTTP proxy
    "github": {
      // Credentials are evaluated top-to-bottom, first match wins.
      //
      // Recommended strategy:
      //   1. Fine-grained PATs scoped to specific orgs/users (least privilege)
      //   2. Classic PAT for repos that don't support fine-grained PATs
      //   3. Broad fine-grained PAT as fallback for public repos
      "credentials": [
        // Fine-grained PAT scoped to your org
        {
          "token": "github_pat_YOUR_ORG_PAT",
          "resources": ["your-org/*"]
        },

        // Fine-grained PAT scoped to your personal repos
        {
          "token": "github_pat_YOUR_PERSONAL_PAT",
          "resources": ["your-username/*"]
        },

        // Classic PAT for external repos that need write access
        // (some orgs/repos don't accept fine-grained PATs from outside collaborators)
        {
          "token": "ghp_YOUR_CLASSIC_PAT",
          "resources": [
            "some-org/specific-repo",
            "another-org/another-repo"
          ]
        },

        // Broad fine-grained PAT as fallback (e.g. for reading public repos)
        {
          "token": "github_pat_YOUR_FALLBACK_PAT",
          "resources": ["*"]
        }
      ]
    },

    // Notion: notion CLI (4ier/notion-cli)
    "notion": {
      "credentials": [
        {
          // Internal Integration Token from https://www.notion.so/profile/integrations
          "token": "ntn_YOUR_INTEGRATION_TOKEN",
          "resources": ["*"]
        }
      ]
    },

    // HTTP proxy: forward requests to upstream APIs with credential injection.
    // No CLI binary needed — sandbox uses curl directly.
    // Usage: curl $FGAP_PROXY_URL/proxy/{service}/{path}
    "http_proxy": {
      "services": {
        // Example: static bearer token
        // "myapi": {
        //   "upstream": "https://api.example.com",
        //   "auth": "bearer",
        //   "credentials": [
        //     {"token": "YOUR_ACCESS_TOKEN", "resources": ["*"]}
        //   ]
        // },

        // Example: OAuth2 with automatic token refresh
        // "freee": {
        //   "upstream": "https://api.freee.co.jp",
        //   "auth": "oauth2",
        //   "oauth2": {
        //     "token_url": "https://accounts.secure.freee.co.jp/public_api/token",
        //     "client_id": "YOUR_CLIENT_ID",
        //     "client_secret": "YOUR_CLIENT_SECRET",
        //     "refresh_token": "YOUR_REFRESH_TOKEN"
        //   },
        //   "credentials": [
        //     {"token": "INITIAL_ACCESS_TOKEN", "resources": ["*"]}
        //   ]
        // }
      }
    },

    // Google: gog CLI (Google Workspace)
    "google": {
      "credentials": [
        // Option 1: OAuth (keyring-based)
        {
          // Password for gog's keyring (~/.config/gogcli/)
          "keyring_password": "your-keyring-password",

          // Optional: restrict to a specific Google account
          // "account": "user@gmail.com",

          "resources": ["*"]
        },

        // Option 2: Service account (no OAuth needed, no token expiry)
        // The SA can only access resources explicitly shared with its email.
        // {
        //   "sa_key_file": "/path/to/service-account-key.json",
        //   "account": "my-sa@my-project.iam.gserviceaccount.com",
        //   "resources": ["*"]
        // }
      ]
    }
  }
}
